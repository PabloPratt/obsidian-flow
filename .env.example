# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Market Data ────────────────────────────────────────────────────────────────
POLYGON_API_KEY=
UNUSUAL_WHALES_API_KEY=your_key_here  # get at unusualwhales.com/api

# ── Brokerage ──────────────────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Alternative Data (all free) ────────────────────────────────────────────────
# NASA: api.nasa.gov — free, instant. DEMO_KEY works but rate-limited.
NASA_API_KEY=DEMO_KEY

# OpenSky ADS-B: opensky-network.org — anonymous works, account increases limits
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# MarineTraffic AIS: marinetraffic.com — paid. Free alt: aisstream.io
MARINETRAFFIC_API_KEY=

# ── News ───────────────────────────────────────────────────────────────────────
# NewsAPI: newsapi.org — free tier: 100 req/day, 1-month history
NEWS_API_KEY=

# ── Macro / Energy ─────────────────────────────────────────────────────────────
# FRED: fred.stlouisfed.org/docs/api/api_key.html — free, instant approval
FRED_API_KEY=

# EIA: eia.gov/opendata/register.php — free, instant approval
EIA_API_KEY=

# ── FDA ────────────────────────────────────────────────────────────────────────
# openFDA works without a key (1000 req/day). Key raises limit to 120k/day.
# Register at: open.fda.gov/apis/authentication/
FDA_API_KEY=

# ── No key required (free public APIs) ────────────────────────────────────────
# SEC EDGAR:         sec.gov/developer          ✓ no key needed
# ClinicalTrials:    clinicaltrials.gov/api/v2  ✓ no key needed
# arXiv:             arxiv.org/help/api         ✓ no key needed
# USASpending.gov:   api.usaspending.gov        ✓ no key needed
